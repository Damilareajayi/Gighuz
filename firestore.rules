rules_version = '2';

// Local emulator only — the backend (Admin SDK) bypasses these rules entirely.
// Client SDKs never talk to Firestore directly in this app; all reads/writes
// go through the Express API, so we just lock the emulator down by default.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
